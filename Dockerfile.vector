FROM node:22-alpine AS builder
WORKDIR /app
COPY package*.json tsconfig.json ./
RUN npm ci
COPY src/vector ./src/vector
COPY scripts ./scripts
RUN npm run build

# Build the IVF-Flat index (runs k-means + writes index.bin)
COPY resources ./resources
RUN node dist/scripts/build-index.js

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/dist/src/vector ./dist/src/vector
COPY --from=builder /app/index.bin .
CMD ["node", "dist/src/vector/server.js"]
